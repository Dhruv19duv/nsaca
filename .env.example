# NSACA Environment Configuration

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Vector Database
VECTOR_DB_PATH=./data/vector_store
VECTOR_DB_DIMENSION=1536

# Rust DSA Engine
RUST_DSA_ENGINE_PATH=./rust/target/release/nsaca_dsa

# Distributed Execution
MAX_WORKERS=4
BENCHMARK_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Docker
DOCKER_REGISTRY=nsaca
IMAGE_TAG=latest
